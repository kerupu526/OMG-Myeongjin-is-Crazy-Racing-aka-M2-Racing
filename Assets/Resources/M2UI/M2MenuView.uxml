                            <ui:Button name="avatar-preset-3" class="avatar-preset"><ui:VisualElement class="avatar avatar--preset"><ui:VisualElement name="avatar-ear-left" class="avatar-ear avatar-ear--left" /><ui:VisualElement name="avatar-ear-right" class="avatar-ear avatar-ear--right" /><ui:VisualElement name="avatar-body" class="avatar-body" /><ui:VisualElement name="avatar-eyes" class="avatar-eyes"><ui:VisualElement class="avatar-eye"><ui:VisualElement class="avatar-eye-shine" /></ui:VisualElement><ui:VisualElement class="avatar-eye"><ui:VisualElement class="avatar-eye-shine" /></ui:VisualElement></ui:VisualElement><ui:VisualElement name="avatar-cheeks" class="avatar-cheeks"><ui:VisualElement class="avatar-cheek" /><ui:VisualElement class="avatar-cheek" /></ui:VisualElement><ui:VisualElement name="avatar-mouth" class="avatar-mouth" /><ui:VisualElement name="avatar-hat" class="avatar-hat" picking-mode="Ignore"><ui:VisualElement name="avatar-hat-cap-top" class="avatar-hat-cap-top" picking-mode="Ignore" /><ui:VisualElement name="avatar-hat-cap-brim" class="avatar-hat-cap-brim" picking-mode="Ignore" /><ui:Image name="avatar-hat-crown" class="avatar-hat-crown" picking-mode="Ignore" /></ui:VisualElement><ui:Label name="avatar-plate" class="avatar-plate" /></ui:VisualElement></ui:Button>
                            <ui:Button name="avatar-preset-4" class="avatar-preset"><ui:VisualElement class="avatar avatar--preset"><ui:VisualElement name="avatar-ear-left" class="avatar-ear avatar-ear--left" /><ui:VisualElement name="avatar-ear-right" class="avatar-ear avatar-ear--right" /><ui:VisualElement name="avatar-body" class="avatar-body" /><ui:VisualElement name="avatar-eyes" class="avatar-eyes"><ui:VisualElement class="avatar-eye"><ui:VisualElement class="avatar-eye-shine" /></ui:VisualElement><ui:VisualElement class="avatar-eye"><ui:VisualElement class="avatar-eye-shine" /></ui:VisualElement></ui:VisualElement><ui:VisualElement name="avatar-cheeks" class="avatar-cheeks"><ui:VisualElement class="avatar-cheek" /><ui:VisualElement class="avatar-cheek" /></ui:VisualElement><ui:VisualElement name="avatar-mouth" class="avatar-mouth" /><ui:VisualElement name="avatar-hat" class="avatar-hat" picking-mode="Ignore"><ui:VisualElement name="avatar-hat-cap-top" class="avatar-hat-cap-top" picking-mode="Ignore" /><ui:VisualElement name="avatar-hat-cap-brim" class="avatar-hat-cap-brim" picking-mode="Ignore" /><ui:Image name="avatar-hat-crown" class="avatar-hat-crown" picking-mode="Ignore" /></ui:VisualElement><ui:Label name="avatar-plate" class="avatar-plate" /></ui:VisualElement></ui:Button>
                        </ui:VisualElement>
                    </ui:VisualElement>
                    <ui:VisualElement class="avatar-nickname"><ui:Label text="닉네임" class="nickname-label" /><ui:TextField name="avatar-name-input" class="avatar-name-input" /><ui:Label name="avatar-preview-name" text="레이서 #001" class="screen-hidden-copy" /><ui:Label name="avatar-summary" text="#001" class="screen-hidden-copy" /></ui:VisualElement>
                </ui:VisualElement>
                <ui:VisualElement class="paper-card avatar-options-card">
                    <ui:VisualElement class="avatar-options-grid">
                        <ui:VisualElement class="avatar-option-group avatar-option-group--wide"><ui:Label text="몸 색상" class="option-label" /><ui:VisualElement class="avatar-color-row"><ui:Button name="avatar-color-0" class="color-swatch" /><ui:Button name="avatar-color-1" class="color-swatch" /><ui:Button name="avatar-color-2" class="color-swatch" /><ui:Button name="avatar-color-3" class="color-swatch" /><ui:Button name="avatar-color-4" class="color-swatch" /><ui:Button name="avatar-color-5" class="color-swatch" /></ui:VisualElement></ui:VisualElement>
                        <ui:VisualElement class="avatar-option-group"><ui:Label text="눈" class="option-label" /><ui:VisualElement class="option-row"><ui:Button name="avatar-eyes-round" class="chip-button chip-button--mint"><ui:Label name="button-label" text="👀 방울눈" /></ui:Button><ui:Button name="avatar-eyes-happy" class="chip-button chip-button--mint"><ui:Label name="button-label" text="😊 웃는눈" /></ui:Button><ui:Button name="avatar-eyes-cool" class="chip-button chip-button--mint"><ui:Label name="button-label" text="😎 선글라스" /></ui:Button></ui:VisualElement></ui:VisualElement>
                        <ui:VisualElement class="avatar-option-group"><ui:Label text="입" class="option-label" /><ui:VisualElement class="option-row"><ui:Button name="avatar-mouth-smile" class="chip-button chip-button--yellow"><ui:Label name="button-label" text="방긋" /></ui:Button><ui:Button name="avatar-mouth-open" class="chip-button chip-button--yellow"><ui:Label name="button-label" text="우와" /></ui:Button><ui:Button name="avatar-mouth-flat" class="chip-button chip-button--yellow"><ui:Label name="button-label" text="시크" /></ui:Button></ui:VisualElement></ui:VisualElement>
                        <ui:VisualElement class="avatar-option-group"><ui:Label text="볼터치" class="option-label" /><ui:VisualElement class="option-row"><ui:Button name="avatar-cheeks-on" class="chip-button chip-button--softpink"><ui:Label name="button-label" text="있음" /></ui:Button><ui:Button name="avatar-cheeks-off" class="chip-button chip-button--muted"><ui:Label name="button-label" text="없음" /></ui:Button></ui:VisualElement></ui:VisualElement>
                        <ui:VisualElement class="avatar-option-group"><ui:Label text="귀" class="option-label" /><ui:VisualElement class="option-row"><ui:Button name="avatar-ears-on" class="chip-button chip-button--cyan"><ui:Label name="button-label" text="있음" /></ui:Button><ui:Button name="avatar-ears-off" class="chip-button chip-button--muted"><ui:Label name="button-label" text="없음" /></ui:Button></ui:VisualElement></ui:VisualElement>
                        <ui:VisualElement class="avatar-option-group"><ui:Label text="모자 / 악세서리" class="option-label" /><ui:VisualElement class="option-row"><ui:Button name="avatar-hat-none" class="chip-button chip-button--softpink"><ui:Label name="button-label" text="없음" /></ui:Button><ui:Button name="avatar-hat-cap" class="chip-button chip-button--muted"><ui:Label name="button-label" text="🧢 캡모자" /></ui:Button><ui:Button name="avatar-hat-crown" class="chip-button chip-button--muted"><ui:Label name="button-label" text="👑 왕관" /></ui:Button></ui:VisualElement></ui:VisualElement>
                        <ui:VisualElement class="avatar-option-group"><ui:Label text="번호판" class="option-label" /><ui:VisualElement class="option-row"><ui:Button name="avatar-plate-0" class="chip-button chip-button--cyan"><ui:Label name="button-label" text="#001" /></ui:Button><ui:Button name="avatar-plate-1" class="chip-button chip-button--muted"><ui:Label name="button-label" text="#077" /></ui:Button><ui:Button name="avatar-plate-2" class="chip-button chip-button--muted"><ui:Label name="button-label" text="#999" /></ui:Button></ui:VisualElement></ui:VisualElement>
                    </ui:VisualElement>
                    <ui:Button name="avatar-save-button" class="avatar-save-button"><ui:Image name="avatar-save-icon" class="large-button-icon" /><ui:Label name="button-label" text="저장하기" /></ui:Button>
                    <ui:Label name="avatar-feedback" text="외형과 이름을 고른 뒤 저장하세요." class="screen-hidden-copy" />
                </ui:VisualElement>
            </ui:VisualElement>
        </ui:VisualElement>

        <!-- Settings -->
        <ui:VisualElement name="screen-settings" class="m2-screen screen-settings">
            <ui:Image name="settings-gradient" class="screen-gradient" picking-mode="Ignore" />
            <ui:Label name="settings-deco-gear" text="⚙️" class="screen-deco settings-deco settings-deco--gear" picking-mode="Ignore" />
            <ui:Label name="settings-deco-spark" text="✦" class="screen-deco settings-deco settings-deco--spark" picking-mode="Ignore" />
            <ui:VisualElement class="settings-topbar"><ui:Button name="settings-back-button" class="back-button"><ui:Label name="button-label" text="← 뒤로" /></ui:Button><ui:Label text="환경설정" class="page-heading" /></ui:VisualElement>
            <ui:VisualElement class="settings-layout">
                <ui:VisualElement class="card-shadow settings-card-shadow settings-card-shadow--sound" picking-mode="Ignore" />
                <ui:VisualElement class="card-shadow settings-card-shadow settings-card-shadow--game" picking-mode="Ignore" />
                <ui:VisualElement class="paper-card settings-panel settings-panel--sound">
                    <ui:Label text="🔊 사운드" class="settings-panel-title" />
                    <ui:VisualElement class="setting-slider-group"><ui:VisualElement class="setting-slider-heading"><ui:Label text="마스터 볼륨" /><ui:Label name="settings-master-value" class="setting-slider-value" /></ui:VisualElement><ui:Slider name="settings-master-slider" low-value="0" high-value="1" show-input-field="false" class="m2-slider m2-slider--pink" /></ui:VisualElement>
                    <ui:VisualElement class="setting-slider-group"><ui:VisualElement class="setting-slider-heading"><ui:Label text="배경음악 (BGM)" /><ui:Label name="settings-bgm-value" class="setting-slider-value" /></ui:VisualElement><ui:Slider name="settings-bgm-slider" low-value="0" high-value="1" show-input-field="false" class="m2-slider m2-slider--cyan" /></ui:VisualElement>
                    <ui:VisualElement class="setting-slider-group"><ui:VisualElement class="setting-slider-heading"><ui:Label text="효과음 (SFX)" /><ui:Label name="settings-sfx-value" class="setting-slider-value" /></ui:VisualElement><ui:Slider name="settings-sfx-slider" low-value="0" high-value="1" show-input-field="false" class="m2-slider m2-slider--mint" /></ui:VisualElement>
                </ui:VisualElement>
                <ui:VisualElement class="paper-card settings-panel">
                    <ui:Label text="🖥️ 화면 &amp; 게임" class="settings-panel-title" />
                    <ui:Label text="그래픽 품질" class="option-label settings-option-label" /><ui:VisualElement class="option-row"><ui:Button name="settings-quality-low" class="chip-button chip-button--muted"><ui:Label name="button-label" text="낮음" /></ui:Button><ui:Button name="settings-quality-medium" class="chip-button chip-button--muted"><ui:Label name="button-label" text="보통" /></ui:Button><ui:Button name="settings-quality-high" class="chip-button chip-button--yellow"><ui:Label name="button-label" text="높음" /></ui:Button></ui:VisualElement>
                    <ui:Label text="화면 모드" class="option-label settings-option-label" /><ui:VisualElement class="option-row"><ui:Button name="settings-fullscreen-button" class="chip-button chip-button--cyan"><ui:Label name="button-label" text="전체화면" /></ui:Button><ui:Button name="settings-windowed-button" class="chip-button chip-button--muted"><ui:Label name="button-label" text="창모드" /></ui:Button></ui:VisualElement>
                    <ui:Label text="언어" class="option-label settings-option-label" /><ui:VisualElement class="option-row"><ui:Button name="settings-language-korean" class="chip-button chip-button--softpink"><ui:Label name="button-label" text="한국어" /></ui:Button><ui:Button name="settings-language-english" class="chip-button chip-button--muted"><ui:Label name="button-label" text="English" /></ui:Button></ui:VisualElement>
                    <ui:Label text="조작키" class="option-label settings-option-label" />
                    <ui:VisualElement class="control-key-row">
                        <ui:Label text="↑ ↓ / W S  가속·후진" />
                        <ui:Label text="← → / A D  조향" />
                        <ui:Label text="Shift  드리프트" />
                        <ui:Label text="Ctrl  가속 아이템" />
                        <ui:Label text="E  공격·방어" />
                    </ui:VisualElement>
                    <ui:VisualElement class="settings-spacer" />
                    <ui:Button name="settings-save-button" class="settings-save-button"><ui:Image name="settings-save-icon" class="large-button-icon" /><ui:Label name="button-label" text="적용" /></ui:Button>
                    <ui:Button name="settings-reset-button" class="screen-hidden-control"><ui:Label name="button-label" text="기본값" /></ui:Button>
                    <ui:Label name="settings-feedback" text="변경한 뒤 저장하면 다음 실행에도 유지됩니다." class="screen-hidden-copy" />
                </ui:VisualElement>
            </ui:VisualElement>
        </ui:VisualElement>
    </ui:VisualElement>
</ui:UXML>
