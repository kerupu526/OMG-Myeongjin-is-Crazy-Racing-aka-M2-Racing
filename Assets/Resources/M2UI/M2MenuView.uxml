<ui:UXML xmlns:ui="UnityEngine.UIElements">
    <ui:VisualElement name="m2-app" class="m2-app">
        <!-- Main -->
        <ui:VisualElement name="screen-main" class="m2-screen screen-main">
            <ui:Image name="main-gradient" class="screen-gradient" picking-mode="Ignore" />
            <ui:Label name="main-deco-spark" text="✦" class="screen-deco main-deco main-deco--spark" picking-mode="Ignore" />
            <ui:Label name="main-deco-star" text="⭐" class="screen-deco main-deco main-deco--star" picking-mode="Ignore" />
            <ui:Label name="main-deco-shine" text="💫" class="screen-deco main-deco main-deco--shine" picking-mode="Ignore" />
            <ui:Label name="main-deco-swirl" text="🌀" class="screen-deco main-deco main-deco--swirl" picking-mode="Ignore" />
            <ui:Label name="main-deco-flag" text="🏁" class="screen-deco main-deco main-deco--flag" picking-mode="Ignore" />
            <ui:Image name="main-photo-mj1" class="main-photo main-photo--mj1" picking-mode="Ignore" />
            <ui:Image name="main-photo-mj2" class="main-photo main-photo--mj2" picking-mode="Ignore" />
            <ui:Image name="main-photo-portrait" class="main-photo main-photo--portrait" picking-mode="Ignore" />

            <ui:VisualElement class="main-heading" picking-mode="Ignore">
                <ui:VisualElement class="m2-wordmark">
                    <ui:Label text="M2" class="m2-wordmark-shadow" />
                    <ui:Label text="M2" class="m2-wordmark-front" />
                </ui:VisualElement>
                <ui:Label text="MAYHEM CRAZY RACING 2" class="main-subtitle" />
                <ui:Label text="인평에서 레이싱으로 미쳐 날뛰어보자 🏁" class="main-tagline" />
            </ui:VisualElement>

            <ui:VisualElement class="main-layout">
                <ui:VisualElement class="main-racer-card-wrap">
                    <ui:VisualElement class="main-racer-card-shadow" picking-mode="Ignore" />
                    <ui:VisualElement class="paper-card main-racer-card">
                        <ui:Label text="✦ 내 아바타" class="avatar-card-kicker" />
                        <ui:VisualElement name="main-avatar" class="avatar avatar--main">
                            <ui:VisualElement class="avatar-body-shadow" picking-mode="Ignore" />
                            <ui:VisualElement name="avatar-ear-left" class="avatar-ear avatar-ear--left" />
                            <ui:VisualElement name="avatar-ear-right" class="avatar-ear avatar-ear--right" />
                            <ui:VisualElement name="avatar-body" class="avatar-body" />
                            <ui:VisualElement name="avatar-eyes" class="avatar-eyes">
                                <ui:VisualElement class="avatar-eye"><ui:VisualElement class="avatar-eye-shine" /></ui:VisualElement>
                                <ui:VisualElement class="avatar-eye"><ui:VisualElement class="avatar-eye-shine" /></ui:VisualElement>
                            </ui:VisualElement>
                            <ui:VisualElement name="avatar-cheeks" class="avatar-cheeks"><ui:VisualElement class="avatar-cheek" /><ui:VisualElement class="avatar-cheek" /></ui:VisualElement>
                            <ui:VisualElement name="avatar-mouth" class="avatar-mouth" />
                            <ui:VisualElement name="avatar-hat" class="avatar-hat" picking-mode="Ignore"><ui:VisualElement name="avatar-hat-cap-top" class="avatar-hat-cap-top" picking-mode="Ignore" /><ui:VisualElement name="avatar-hat-cap-brim" class="avatar-hat-cap-brim" picking-mode="Ignore" /><ui:Image name="avatar-hat-crown" class="avatar-hat-crown" picking-mode="Ignore" /></ui:VisualElement>
                            <ui:Label name="avatar-plate" class="avatar-plate" />
                        </ui:VisualElement>
                        <ui:Label name="main-racer-name" text="레이서 #001" class="main-racer-name" />
                        <ui:Button name="main-avatar-button" class="pill-button avatar-customize-button"><ui:Label name="button-label" text="▶ 꾸미기" /></ui:Button>
                    </ui:VisualElement>
                </ui:VisualElement>

                <ui:VisualElement class="main-action-stack">
                    <ui:VisualElement class="hero-button-wrap"><ui:VisualElement class="hero-button-shadow" picking-mode="Ignore" /><ui:Button name="main-create-button" class="hero-button hero-button--pink"><ui:Label name="button-label" text="방 만들기" /><ui:VisualElement class="hero-button-icon-stack" picking-mode="Ignore"><ui:Image name="main-create-icon-shadow" class="hero-button-icon icon-shadow" picking-mode="Ignore" /><ui:Image name="main-create-icon" class="hero-button-icon icon-front" picking-mode="Ignore" /></ui:VisualElement></ui:Button></ui:VisualElement>
                    <ui:VisualElement class="hero-button-wrap"><ui:VisualElement class="hero-button-shadow" picking-mode="Ignore" /><ui:Button name="main-join-button" class="hero-button hero-button--cyan"><ui:Label name="button-label" text="방 참가하기" /><ui:VisualElement class="hero-button-icon-stack" picking-mode="Ignore"><ui:Image name="main-join-icon-shadow" class="hero-button-icon icon-shadow" picking-mode="Ignore" /><ui:Image name="main-join-icon" class="hero-button-icon icon-front" picking-mode="Ignore" /></ui:VisualElement></ui:Button></ui:VisualElement>
                    <ui:VisualElement class="hero-button-wrap"><ui:VisualElement class="hero-button-shadow" picking-mode="Ignore" /><ui:Button name="main-avatar-settings-button" class="hero-button hero-button--mint"><ui:Label name="button-label" text="아바타 설정" /><ui:VisualElement class="hero-button-icon-stack" picking-mode="Ignore"><ui:Image name="main-avatar-icon-shadow" class="hero-button-icon icon-shadow" picking-mode="Ignore" /><ui:Image name="main-avatar-icon" class="hero-button-icon icon-front" picking-mode="Ignore" /></ui:VisualElement></ui:Button></ui:VisualElement>
                    <ui:VisualElement class="hero-button-wrap"><ui:VisualElement class="hero-button-shadow" picking-mode="Ignore" /><ui:Button name="main-settings-button" class="hero-button hero-button--yellow"><ui:Label name="button-label" text="환경설정" /><ui:VisualElement class="hero-button-icon-stack" picking-mode="Ignore"><ui:Image name="main-settings-icon-shadow" class="hero-button-icon icon-shadow" picking-mode="Ignore" /><ui:Image name="main-settings-icon" class="hero-button-icon icon-front" picking-mode="Ignore" /></ui:VisualElement></ui:Button></ui:VisualElement>
                </ui:VisualElement>
            </ui:VisualElement>

            <ui:Button name="main-race-test-button" class="race-test-button"><ui:Label name="button-label" text="▶ 로컬 레이스 테스트" /></ui:Button>

            <ui:Label text="레이스 온 🔥" class="main-sticker main-sticker--on" picking-mode="Ignore" />
            <ui:Label text="누가 1등? 😏" class="main-sticker main-sticker--winner" picking-mode="Ignore" />
            <ui:Label text="© 2026 인평랜드 · 학교축제 에디션" class="main-copyright" picking-mode="Ignore" />
            <ui:Label name="main-feedback" text="방 만들기 또는 방 참가를 선택하세요." class="main-feedback" />
        </ui:VisualElement>

        <!-- Network operation overlays -->
        <ui:VisualElement name="screen-host" class="m2-screen functional-screen">
            <ui:Image name="host-gradient" class="screen-gradient" picking-mode="Ignore" />
            <ui:Label text="✦" class="screen-deco functional-deco functional-deco--left" picking-mode="Ignore" />
            <ui:Label text="🏁" class="screen-deco functional-deco functional-deco--right" picking-mode="Ignore" />
            <ui:VisualElement class="functional-header"><ui:Button name="host-back-button" class="back-button"><ui:Label name="button-label" text="← 뒤로" /></ui:Button><ui:VisualElement class="functional-title-wrap"><ui:Label text="방 만들기" class="functional-title" /><ui:Label text="친구와 함께 달릴 프라이빗 레이스를 설정하세요." class="functional-subtitle" /></ui:VisualElement></ui:VisualElement>
            <ui:VisualElement class="card-shadow functional-card-shadow functional-card-shadow--host" picking-mode="Ignore" />
            <ui:VisualElement class="functional-card functional-card--host">
                <ui:Label text="⚙️ 게임 설정" class="functional-card-title" />
                <ui:Label text="게임 모드" class="functional-field-label" />
                <ui:Button name="host-mode-button" class="chip-button chip-button--yellow"><ui:Label name="button-label" /></ui:Button>
                <ui:Label text="바퀴 수" class="functional-field-label" />
                <ui:Button name="host-lap-button" class="chip-button chip-button--mint"><ui:Label name="button-label" /></ui:Button>
                <ui:Label text="승리 조건" class="functional-field-label" />
                <ui:Button name="host-victory-button" class="chip-button chip-button--purple"><ui:Label name="button-label" /></ui:Button>
                <ui:VisualElement class="functional-fill" />
                <ui:Button name="host-create-button" class="large-primary-button"><ui:Image name="host-flag-icon" class="large-button-icon" /><ui:Label name="button-label" text="방 만들기" /></ui:Button>
                <ui:Label name="host-feedback" text="모드와 규칙을 정한 뒤 방을 만드세요." class="functional-feedback" />
            </ui:VisualElement>
        </ui:VisualElement>

        <ui:VisualElement name="screen-join" class="m2-screen functional-screen">
            <ui:Image name="join-gradient" class="screen-gradient" picking-mode="Ignore" />
            <ui:Label text="✦" class="screen-deco functional-deco functional-deco--left" picking-mode="Ignore" />
            <ui:Label text="🎮" class="screen-deco functional-deco functional-deco--right" picking-mode="Ignore" />
            <ui:VisualElement class="functional-header"><ui:Button name="join-back-button" class="back-button"><ui:Label name="button-label" text="← 뒤로" /></ui:Button><ui:VisualElement class="functional-title-wrap"><ui:Label text="방 참가하기" class="functional-title" /><ui:Label text="친구에게 받은 M2 방 코드로 합류하세요." class="functional-subtitle" /></ui:VisualElement></ui:VisualElement>
            <ui:VisualElement class="card-shadow functional-card-shadow functional-card-shadow--join" picking-mode="Ignore" />
            <ui:VisualElement class="functional-card functional-card--join">
                <ui:Image name="join-door-icon" class="join-door-icon" />
                <ui:Label text="방 코드 입력" class="functional-card-title" />
                <ui:Label text="예시 · M2-7X4K" class="join-example" />
                <ui:TextField name="join-room-code-input" class="room-code-input" />
                <ui:Button name="join-submit-button" class="large-primary-button large-primary-button--pink join-submit-button"><ui:Image name="join-submit-icon-shadow" class="large-button-icon icon-shadow-inline" picking-mode="Ignore" /><ui:Image name="host-crown-icon" class="large-button-icon" picking-mode="Ignore" /><ui:Label name="button-label" text="방 참가" /></ui:Button>
                <ui:Label name="join-feedback" text="친구에게 받은 방 코드를 입력하세요." class="functional-feedback" />
            </ui:VisualElement>
        </ui:VisualElement>

        <!-- Lobby -->
        <ui:VisualElement name="screen-lobby" class="m2-screen screen-lobby">
            <ui:Image name="lobby-gradient" class="screen-gradient" picking-mode="Ignore" />
            <ui:Label name="lobby-deco-gamepad" text="🎮" class="screen-deco lobby-deco lobby-deco--gamepad" picking-mode="Ignore" />
            <ui:Label name="lobby-deco-spark" text="✦" class="screen-deco lobby-deco lobby-deco--spark" picking-mode="Ignore" />
            <ui:VisualElement class="lobby-topbar">
                <ui:VisualElement class="lobby-topbar-left"><ui:Button name="lobby-leave-button" class="back-button lobby-leave-button"><ui:Label name="button-label" text="← 나가기" /></ui:Button><ui:VisualElement class="arcade-sign"><ui:Label text="🕹️ 인평이네 오락실" /></ui:VisualElement></ui:VisualElement>
                <ui:VisualElement class="room-code-sign"><ui:Label text="방 코드" class="room-code-caption" /><ui:Label name="lobby-room-code" text="M2-7X4K" class="room-code-value" /></ui:VisualElement>
            </ui:VisualElement>
            <ui:VisualElement class="lobby-layout">
                <ui:VisualElement class="card-shadow lobby-player-shadow lobby-player-shadow--host" picking-mode="Ignore" />
                <ui:VisualElement class="card-shadow lobby-player-shadow lobby-player-shadow--guest" picking-mode="Ignore" />
                <ui:VisualElement class="card-shadow lobby-settings-shadow" picking-mode="Ignore" />
                <ui:VisualElement class="lobby-player-column">
                    <ui:VisualElement class="paper-card lobby-player-card lobby-player-card--host">
                        <ui:VisualElement class="host-badge"><ui:Image name="lobby-crown-icon" class="small-icon" /><ui:Label text="방장" /></ui:VisualElement>
                        <ui:VisualElement name="lobby-host-avatar" class="avatar avatar--lobby">
                            <ui:VisualElement name="avatar-ear-left" class="avatar-ear avatar-ear--left" /><ui:VisualElement name="avatar-ear-right" class="avatar-ear avatar-ear--right" /><ui:VisualElement name="avatar-body" class="avatar-body" /><ui:VisualElement name="avatar-eyes" class="avatar-eyes"><ui:VisualElement class="avatar-eye"><ui:VisualElement class="avatar-eye-shine" /></ui:VisualElement><ui:VisualElement class="avatar-eye"><ui:VisualElement class="avatar-eye-shine" /></ui:VisualElement></ui:VisualElement><ui:VisualElement name="avatar-cheeks" class="avatar-cheeks"><ui:VisualElement class="avatar-cheek" /><ui:VisualElement class="avatar-cheek" /></ui:VisualElement><ui:VisualElement name="avatar-mouth" class="avatar-mouth" /><ui:VisualElement name="avatar-hat" class="avatar-hat" picking-mode="Ignore"><ui:VisualElement name="avatar-hat-cap-top" class="avatar-hat-cap-top" picking-mode="Ignore" /><ui:VisualElement name="avatar-hat-cap-brim" class="avatar-hat-cap-brim" picking-mode="Ignore" /><ui:Image name="avatar-hat-crown" class="avatar-hat-crown" picking-mode="Ignore" /></ui:VisualElement><ui:Label name="avatar-plate" class="avatar-plate" />
                        </ui:VisualElement>
                        <ui:VisualElement class="lobby-player-copy"><ui:Label name="lobby-host-name" text="레이서 #001" class="lobby-player-name" /><ui:Label name="lobby-host-meta" text="저번 대회 우승자 · Lv.99" class="lobby-player-meta" /><ui:Label name="lobby-host-ready" text="✓ 준비 완료" class="ready-pill ready-pill--ready" /></ui:VisualElement>
                    </ui:VisualElement>
                    <ui:VisualElement class="paper-card lobby-player-card">
                        <ui:VisualElement name="lobby-guest-avatar" class="avatar avatar--lobby avatar--cyan">
                            <ui:VisualElement name="avatar-ear-left" class="avatar-ear avatar-ear--left" /><ui:VisualElement name="avatar-ear-right" class="avatar-ear avatar-ear--right" /><ui:VisualElement name="avatar-body" class="avatar-body" /><ui:VisualElement name="avatar-eyes" class="avatar-eyes"><ui:VisualElement class="avatar-eye"><ui:VisualElement class="avatar-eye-shine" /></ui:VisualElement><ui:VisualElement class="avatar-eye"><ui:VisualElement class="avatar-eye-shine" /></ui:VisualElement></ui:VisualElement><ui:VisualElement name="avatar-cheeks" class="avatar-cheeks"><ui:VisualElement class="avatar-cheek" /><ui:VisualElement class="avatar-cheek" /></ui:VisualElement><ui:VisualElement name="avatar-mouth" class="avatar-mouth" /><ui:VisualElement name="avatar-hat" class="avatar-hat" picking-mode="Ignore"><ui:VisualElement name="avatar-hat-cap-top" class="avatar-hat-cap-top" picking-mode="Ignore" /><ui:VisualElement name="avatar-hat-cap-brim" class="avatar-hat-cap-brim" picking-mode="Ignore" /><ui:Image name="avatar-hat-crown" class="avatar-hat-crown" picking-mode="Ignore" /></ui:VisualElement><ui:Label name="avatar-plate" class="avatar-plate" />
                        </ui:VisualElement>
                        <ui:VisualElement class="lobby-player-copy"><ui:Label name="lobby-guest-name" text="상대 접속 대기" class="lobby-player-name" /><ui:Label name="lobby-guest-meta" text="도전장 접수 · Lv.42" class="lobby-player-meta" /><ui:Label name="lobby-guest-ready" text="준비 중..." class="ready-pill ready-pill--waiting" /></ui:VisualElement>
                    </ui:VisualElement>
                    <ui:VisualElement class="lobby-chat"><ui:Label name="lobby-status" text="💬 친구에게 위 방 코드를 알려주세요." /></ui:VisualElement>
                </ui:VisualElement>
                <ui:VisualElement class="paper-card lobby-settings-card">
                    <ui:VisualElement class="lobby-settings-heading"><ui:Image name="lobby-settings-icon" class="small-icon" picking-mode="Ignore" /><ui:Label text="게임 설정" /></ui:VisualElement>
                    <ui:Label name="lobby-authority" text="방장이 설정을 변경할 수 있습니다." class="lobby-authority" />
                    <ui:Label text="게임 모드" class="lobby-field-label" />
                    <ui:VisualElement class="lobby-chip-row"><ui:Button name="lobby-mode-item-button" class="chip-button chip-button--yellow"><ui:Image name="lobby-mode-icon" class="chip-icon" picking-mode="Ignore" /><ui:Label name="button-label" text="아이템전" /></ui:Button><ui:Button name="lobby-mode-speed-button" class="chip-button chip-button--muted"><ui:Image name="lobby-speed-icon" class="chip-icon" picking-mode="Ignore" /><ui:Label name="button-label" text="스피드전" /></ui:Button></ui:VisualElement>
                    <ui:Label text="바퀴 수" class="lobby-field-label" />
                    <ui:VisualElement class="lobby-chip-row"><ui:Button name="lobby-lap-1-button" class="chip-button chip-button--muted"><ui:Label name="button-label" text="1바퀴" /></ui:Button><ui:Button name="lobby-lap-3-button" class="chip-button chip-button--mint"><ui:Label name="button-label" text="3바퀴" /></ui:Button><ui:Button name="lobby-lap-5-button" class="chip-button chip-button--muted"><ui:Label name="button-label" text="5바퀴" /></ui:Button></ui:VisualElement>
                    <ui:Label text="스테이지" class="lobby-field-label" />
                    <ui:VisualElement class="lobby-chip-row"><ui:Button name="lobby-stage-bikini-button" class="chip-button chip-button--softpink"><ui:Image name="lobby-stage-bikini-icon" class="chip-icon" /><ui:Label name="button-label" text="비키니 시티" /></ui:Button><ui:Button name="lobby-stage-africa-button" class="chip-button chip-button--muted"><ui:Image name="lobby-stage-africa-icon" class="chip-icon" /><ui:Label name="button-label" text="아프리카TV" /></ui:Button><ui:Button name="lobby-stage-nether-button" class="chip-button chip-button--muted"><ui:Image name="lobby-stage-nether-icon" class="chip-icon" /><ui:Label name="button-label" text="네더 요새" /></ui:Button></ui:VisualElement>
                    <ui:Label text="승리 조건" class="lobby-field-label" />
                    <ui:VisualElement class="lobby-chip-row"><ui:Button name="lobby-victory-finish-button" class="chip-button chip-button--muted"><ui:Label name="button-label" text="단순완주" /></ui:Button><ui:Button name="lobby-victory-star-button" class="chip-button chip-button--purple"><ui:Label name="button-label" text="별점내기" /></ui:Button></ui:VisualElement>
                    <ui:VisualElement class="lobby-rule-note"><ui:Image name="lobby-star-icon" class="small-icon" /><ui:Label name="lobby-rules" text="완주 시 획득한 별점이 더 높은 쪽 승리" /></ui:VisualElement>
                    <ui:VisualElement class="lobby-settings-spacer" />
                    <ui:Button name="lobby-ready-button" class="lobby-start-button"><ui:Image name="lobby-ready-icon" class="large-button-icon" /><ui:Label name="button-label" text="게임 시작! 가보자고" /><ui:Image name="lobby-ready-icon-right" class="large-button-icon large-button-icon--trailing" /></ui:Button>
                </ui:VisualElement>
            </ui:VisualElement>
        </ui:VisualElement>

        <!-- Avatar -->
        <ui:VisualElement name="screen-avatar" class="m2-screen screen-avatar">
            <ui:Image name="avatar-gradient" class="screen-gradient" picking-mode="Ignore" />
            <ui:Label name="avatar-deco-left" text="✦" class="screen-deco avatar-deco avatar-deco--left" picking-mode="Ignore" />
            <ui:Label name="avatar-deco-right" text="💫" class="screen-deco avatar-deco avatar-deco--right" picking-mode="Ignore" />
            <ui:VisualElement class="avatar-topbar"><ui:Button name="avatar-back-button" class="back-button"><ui:Label name="button-label" text="← 뒤로" /></ui:Button><ui:Label text="아바타 설정" class="page-heading" /></ui:VisualElement>
            <ui:VisualElement class="avatar-layout">
                <ui:VisualElement class="card-shadow avatar-card-shadow avatar-card-shadow--preview" picking-mode="Ignore" />
                <ui:VisualElement class="card-shadow avatar-card-shadow avatar-card-shadow--options" picking-mode="Ignore" />
                <ui:VisualElement class="paper-card avatar-preview-card">
                    <ui:Label text="✦ 미리보기" class="avatar-preview-kicker" />
                    <ui:VisualElement class="avatar-preview-area"><ui:VisualElement name="avatar-preview" class="avatar avatar--preview"><ui:VisualElement name="avatar-ear-left" class="avatar-ear avatar-ear--left" /><ui:VisualElement name="avatar-ear-right" class="avatar-ear avatar-ear--right" /><ui:VisualElement name="avatar-body" class="avatar-body" /><ui:VisualElement name="avatar-eyes" class="avatar-eyes"><ui:VisualElement class="avatar-eye"><ui:VisualElement class="avatar-eye-shine" /></ui:VisualElement><ui:VisualElement class="avatar-eye"><ui:VisualElement class="avatar-eye-shine" /></ui:VisualElement></ui:VisualElement><ui:VisualElement name="avatar-cheeks" class="avatar-cheeks"><ui:VisualElement class="avatar-cheek" /><ui:VisualElement class="avatar-cheek" /></ui:VisualElement><ui:VisualElement name="avatar-mouth" class="avatar-mouth" /><ui:VisualElement name="avatar-hat" class="avatar-hat" picking-mode="Ignore"><ui:VisualElement name="avatar-hat-cap-top" class="avatar-hat-cap-top" picking-mode="Ignore" /><ui:VisualElement name="avatar-hat-cap-brim" class="avatar-hat-cap-brim" picking-mode="Ignore" /><ui:Image name="avatar-hat-crown" class="avatar-hat-crown" picking-mode="Ignore" /></ui:VisualElement><ui:Label name="avatar-plate" class="avatar-plate" /></ui:VisualElement></ui:VisualElement>
                    <ui:VisualElement class="avatar-presets">
                        <ui:Label text="프리셋" class="option-label" />
                        <ui:VisualElement class="avatar-preset-row">
                            <ui:Button name="avatar-preset-0" class="avatar-preset"><ui:VisualElement class="avatar avatar--preset"><ui:VisualElement name="avatar-ear-left" class="avatar-ear avatar-ear--left" /><ui:VisualElement name="avatar-ear-right" class="avatar-ear avatar-ear--right" /><ui:VisualElement name="avatar-body" class="avatar-body" /><ui:VisualElement name="avatar-eyes" class="avatar-eyes"><ui:VisualElement class="avatar-eye"><ui:VisualElement class="avatar-eye-shine" /></ui:VisualElement><ui:VisualElement class="avatar-eye"><ui:VisualElement class="avatar-eye-shine" /></ui:VisualElement></ui:VisualElement><ui:VisualElement name="avatar-cheeks" class="avatar-cheeks"><ui:VisualElement class="avatar-cheek" /><ui:VisualElement class="avatar-cheek" /></ui:VisualElement><ui:VisualElement name="avatar-mouth" class="avatar-mouth" /><ui:VisualElement name="avatar-hat" class="avatar-hat" picking-mode="Ignore"><ui:VisualElement name="avatar-hat-cap-top" class="avatar-hat-cap-top" picking-mode="Ignore" /><ui:VisualElement name="avatar-hat-cap-brim" class="avatar-hat-cap-brim" picking-mode="Ignore" /><ui:Image name="avatar-hat-crown" class="avatar-hat-crown" picking-mode="Ignore" /></ui:VisualElement><ui:Label name="avatar-plate" class="avatar-plate" /></ui:VisualElement></ui:Button>
                            <ui:Button name="avatar-preset-1" class="avatar-preset"><ui:VisualElement class="avatar avatar--preset"><ui:VisualElement name="avatar-ear-left" class="avatar-ear avatar-ear--left" /><ui:VisualElement name="avatar-ear-right" class="avatar-ear avatar-ear--right" /><ui:VisualElement name="avatar-body" class="avatar-body" /><ui:VisualElement name="avatar-eyes" class="avatar-eyes"><ui:VisualElement class="avatar-eye"><ui:VisualElement class="avatar-eye-shine" /></ui:VisualElement><ui:VisualElement class="avatar-eye"><ui:VisualElement class="avatar-eye-shine" /></ui:VisualElement></ui:VisualElement><ui:VisualElement name="avatar-cheeks" class="avatar-cheeks"><ui:VisualElement class="avatar-cheek" /><ui:VisualElement class="avatar-cheek" /></ui:VisualElement><ui:VisualElement name="avatar-mouth" class="avatar-mouth" /><ui:VisualElement name="avatar-hat" class="avatar-hat" picking-mode="Ignore"><ui:VisualElement name="avatar-hat-cap-top" class="avatar-hat-cap-top" picking-mode="Ignore" /><ui:VisualElement name="avatar-hat-cap-brim" class="avatar-hat-cap-brim" picking-mode="Ignore" /><ui:Image name="avatar-hat-crown" class="avatar-hat-crown" picking-mode="Ignore" /></ui:VisualElement><ui:Label name="avatar-plate" class="avatar-plate" /></ui:VisualElement></ui:Button>
